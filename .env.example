# =============================================================================
# Docker environment — copy to .env before: docker compose up --build
# =============================================================================

# Host ports
BACKEND_PORT=8000
FRONTEND_PORT=5173
POSTGRES_PORT=5432

# PostgreSQL (Docker service name: postgres)
POSTGRES_USER=tomato
POSTGRES_PASSWORD=tomato
POSTGRES_DB=tomato_disease

# Backend — use postgres hostname inside Docker network
DATABASE_URL=postgresql+asyncpg://tomato:tomato@postgres:5432/tomato_disease

# For local backend without Docker, use localhost:
# DATABASE_URL=postgresql+asyncpg://tomato:tomato@localhost:5432/tomato_disease

MODEL_PATH=/app/model_artifacts/best_model.pth
LABELS_PATH=/app/model_artifacts/class_labels.json
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (browser calls API on host — keep localhost, not container name)
VITE_API_URL=http://localhost:8000
